---
import { getRelativeLocaleUrl } from "astro:i18n";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import EntryCard from "@/components/EntryCard.astro";
import LinkButton from "@/components/LinkButton.astro";
import Seal from "@/components/Seal.astro";
import WaveRule from "@/components/WaveRule.astro";
import { getAllEntries } from "@/utils/getAllEntries";
import { useTranslations } from "@/i18n";
import config from "@/config";

const { socials, posts: postsConfig } = config;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

// Posts + research pages, merged and sorted by last update.
const entries = await getAllEntries(locale);
const featuredEntries = entries.filter(entry => entry.featured);
const recentEntries = entries.filter(entry => !entry.featured);
const homePath = getRelativeLocaleUrl(locale, "");
---

<Layout>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout"
  >
    <section id="hero" class="pt-10 pb-8 sm:pt-14">
      <div class="flex items-start justify-between gap-4">
        <div class="hero-intro">
          <h1
            class="font-serif text-4xl leading-snug font-bold tracking-wide sm:text-5xl"
          >
            枫落于川<span class="text-accent">，</span>川流成集
          </h1>
          <p
            class="text-muted-foreground mt-4 font-serif text-base tracking-widest sm:text-lg"
          >
            逝者如斯，而未尝往也
          </p>
        </div>
        <Seal char="集" size={56} class="hero-seal mt-2 shrink-0 sm:mt-4" />
      </div>

      <p class="text-muted-foreground mt-8 max-w-xl">
        这里收录技术文章与论文研读——读过的、想过的，皆汇流于此。
      </p>

      <div
        class="mt-4 flex items-center gap-4 max-sm:flex-col max-sm:items-start"
      >
        {
          socials.length > 0 && (
            <div class="flex items-center">
              <div class="me-2 whitespace-nowrap">{t.home.socialLinks}:</div>
              <Socials />
            </div>
          )
        }
        <a
          target="_blank"
          href={`${import.meta.env.BASE_URL.replace(/\/?$/, "/")}rss.xml`}
          class="inline-flex items-center"
          aria-label="RSS Feed"
          title="RSS Feed"
        >
          <IconRss
            width={18}
            height={18}
            class="stroke-muted-foreground hover:stroke-accent stroke-2 transition-colors rtl:-rotate-90"
          />
          <span class="sr-only">RSS Feed</span>
        </a>
      </div>
    </section>

    <WaveRule />

    {
      featuredEntries.length > 0 && (
        <section id="featured" class="pt-10 pb-6">
          <h2 class="font-serif text-2xl font-semibold tracking-wide">
            {t.home.featured}
          </h2>
          <ul>
            {featuredEntries.map(entry => (
              <EntryCard variant="h3" {entry} />
            ))}
          </ul>
        </section>
      )
    }

    {featuredEntries.length > 0 && recentEntries.length > 0 && <WaveRule />}

    {
      recentEntries.length > 0 && (
        <section id="recent-posts" class="pt-10 pb-6">
          <h2 class="font-serif text-2xl font-semibold tracking-wide">
            {t.home.recentPosts}
          </h2>
          <ul>
            {recentEntries.slice(0, postsConfig.perIndex).map(entry => (
              <EntryCard variant="h3" {entry} />
            ))}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href={getRelativeLocaleUrl(locale, "posts")}>
        {t.home.allPosts}
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  /* hero 入场:题记淡入,朱印轻微下压——一次性,≤400ms */
  @media (prefers-reduced-motion: no-preference) {
    .hero-intro {
      animation: hero-fade 0.4s ease-out both;
    }

    :global(.hero-seal) {
      animation: seal-press 0.4s cubic-bezier(0.2, 0.8, 0.3, 1.1) 0.15s both;
    }
  }

  @keyframes hero-fade {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  @keyframes seal-press {
    from {
      opacity: 0;
      transform: scale(1.15);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }
  });
</script>
