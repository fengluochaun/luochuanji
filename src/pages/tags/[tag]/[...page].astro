---
import type { GetStaticPathsOptions } from "astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Main from "@/components/Main.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import EntryCard from "@/components/EntryCard.astro";
import Footer from "@/components/Footer.astro";
import Pagination from "@/components/Pagination.astro";
import { getAllEntries } from "@/utils/getAllEntries";
import { getUniqueTagsFromEntries } from "@/utils/getUniqueTags";
import { slugifyAll } from "@/utils/slugify";
import { useTranslations } from "@/i18n";
import config from "@/config";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  // Tag pages list posts AND research pages sharing the tag.
  const entries = await getAllEntries(config.site.lang);
  const tags = getUniqueTagsFromEntries(entries);

  return tags.flatMap(({ tag, tagName }) => {
    const tagEntries = entries.filter(entry =>
      slugifyAll(entry.tags).includes(tag)
    );

    return paginate(tagEntries, {
      params: { tag },
      props: { tagName },
      pageSize: config.posts.perPage,
    });
  });
}

const { page, tagName } = Astro.props;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);
---

<Layout title={`${t.pages.tagTitle}: ${tagName} | ${config.site.title}`}>
  <Header />

  <Breadcrumb />

  <Main
    pageTitle={`${t.pages.tagTitle}: ${tagName}`}
    pageDesc={`${t.pages.tagDesc} "${tagName}".`}
  >
    <ul>
      {page.data.map(entry => <EntryCard {entry} />)}
    </ul>
  </Main>

  <Pagination {page} />

  <Footer noMarginTop={page.lastPage > 1} />
</Layout>
