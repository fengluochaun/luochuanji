---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import EntryCard from "@/components/EntryCard.astro";
import Footer from "@/components/Footer.astro";
import { getAllEntries } from "@/utils/getAllEntries";
import { useTranslations } from "@/i18n";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

// 所有论文精读页,按时间倒序(getAllEntries 已排序)。
const entries = (await getAllEntries(locale)).filter(
  entry => entry.type === "research"
);
---

<Layout title={`${t.pages.researchTitle} | ${config.site.title}`}>
  <Header />

  <Breadcrumb />

  <Main pageTitle={t.pages.researchTitle} pageDesc={t.pages.researchDesc}>
    <ul>
      {entries.map(entry => <EntryCard variant="h3" {entry} />)}
    </ul>
  </Main>

  <Footer />
</Layout>
