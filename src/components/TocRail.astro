---
// 共享侧边目录 —— 文章页与论文页复用。
// 服务端传入 { id, title } 列表;≥1440px 固定在版心左侧留白区,
// 更窄视口隐藏。滚动高亮走 IntersectionObserver。
type TocItem = { id: string; title: string };

type Props = {
  items: TocItem[];
  label: string;
  /** 观察目标的选择器前缀:文章用标题 id,论文用 section id */
  targetSelector?: string;
};

const { items, label } = Astro.props;
---

{
  items.length > 1 && (
    <nav class="toc-rail" aria-label={label} data-toc-rail>
      <span class="toc-rail__title">{label}</span>
      <ul>
        {items.map(item => (
          <li>
            <a href={`#${item.id}`}>{item.title}</a>
          </li>
        ))}
      </ul>
    </nav>
  )
}

<style>
  /*
   * 版心 --app-width(52rem=832px)居中,两侧留白 = (100vw - 832)/2。
   * ≥1440px 时单侧留白 ≥304px,放得下 208px 目录 + 间距;更窄则隐藏,
   * 避免与正文重叠。
   */
  .toc-rail {
    display: none;
  }

  @media (min-width: 1440px) {
    .toc-rail {
      display: block;
      position: fixed;
      top: 128px;
      left: calc(50vw - var(--app-width) / 2 - 232px);
      z-index: 5;
      inline-size: 208px;
      max-block-size: calc(100vh - 200px);
      overflow-y: auto;
      font-size: 0.8125rem;
      overscroll-behavior: contain;
    }
  }

  .toc-rail__title {
    display: block;
    margin-block-end: 0.5rem;
    font-family: var(--font-serif);
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--muted-foreground);
  }

  .toc-rail ul {
    margin: 0;
    padding: 0;
    list-style: none;
    border-inline-start: 1px solid var(--border);
  }

  .toc-rail a {
    display: block;
    margin-inline-start: -1px;
    padding: 0.3rem 0.75rem;
    border-inline-start: 2px solid transparent;
    color: var(--muted-foreground);
    line-height: 1.5;
    text-decoration: none;
    /* 长标题截断,避免撑破窄轨 */
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .toc-rail a:hover {
    color: var(--accent);
  }

  .toc-rail a.active {
    border-inline-start-color: var(--accent);
    color: var(--accent);
    white-space: normal;
  }
</style>

<script>
  // 目录滚动高亮:观察各锚点目标,文档序第一个可见者为当前节。
  function initTocRail() {
    const rail = document.querySelector<HTMLElement>("[data-toc-rail]");
    if (!rail) return;

    const links = Array.from(
      rail.querySelectorAll<HTMLAnchorElement>('a[href^="#"]')
    );
    const idOf = (a: HTMLAnchorElement) => decodeURIComponent(a.hash.slice(1));
    const targets = links
      .map(a => document.getElementById(idOf(a)))
      .filter((el): el is HTMLElement => el !== null);
    if (targets.length === 0) return;

    const linkById = new Map(links.map(a => [idOf(a), a]));
    const visible = new Set<string>();

    const setActive = () => {
      const current = targets.find(s => visible.has(s.id));
      for (const [id, link] of linkById) {
        link.classList.toggle("active", id === current?.id);
      }
    };

    const observer = new IntersectionObserver(
      entries => {
        for (const entry of entries) {
          if (entry.isIntersecting) visible.add(entry.target.id);
          else visible.delete(entry.target.id);
        }
        setActive();
      },
      { rootMargin: "-120px 0px -55% 0px" }
    );
    targets.forEach(target => observer.observe(target));
  }

  initTocRail();
  document.addEventListener("astro:after-swap", initTocRail);
</script>
