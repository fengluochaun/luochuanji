---
import type { CollectionEntry } from "astro:content";
import Layout from "./Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Datetime from "@/components/Datetime.astro";
import Tag from "@/components/Tag.astro";
import Comments from "@/components/Comments.astro";
import { slugifyStr } from "@/utils/slugify";
import { useTranslations } from "@/i18n";
import config from "@/config";
import "katex/dist/katex.min.css";

type Props = {
  entry: CollectionEntry<"research">;
  /** Paper body markup produced by `pnpm research:publish` (script-free). */
  contentHtml: string;
  /** Paper CSS already scoped under `.paper-root` by the importer. */
  paperCss: string;
};

const { entry, contentHtml, paperCss } = Astro.props;
const { title, description, date, tags, source, topicTitle, seriesTitle } =
  entry.data;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

/**
 * Compensating reset — injected BEFORE the paper's own scoped CSS so the paper
 * always wins, but AFTER Tailwind Preflight (loaded via global.css in
 * Layout.astro). Preflight neutralises headings, lists and links globally;
 * paper2html pages assume browser defaults for anything they don't style, so
 * we restore those defaults inside `.paper-root` only.
 */
const paperResetCss = `
/* restore browser defaults Tailwind Preflight strips (see PaperLayout.astro) */
.paper-root :where(h1, h2, h3, h4, h5, h6) { font-weight: bold; }
.paper-root :where(ul) { list-style: disc; }
.paper-root :where(ol) { list-style: decimal; }
.paper-root :where(ul, ol):not([class]) { padding-inline-start: 1.5em; }
.paper-root :where(a[href]) { color: var(--blue, #0066cc); text-decoration: underline; }
`;

/**
 * Site-shell harmonization, appended AFTER the scoped paper styles so it wins
 * by source order at equal specificity:
 *
 * - The standalone page reserves top padding for its own fixed navbar, which
 *   the importer strips — the site header sits above the paper in normal
 *   flow instead, so the reserved space is reduced.
 * - Light-mode palette bridge: imported pages ship a cool-grey/apple-blue
 *   palette (--bg #f5f5f7, --blue #0066cc) that reads as a foreign panel on
 *   the warm 宣纸 site theme. Re-pointing --bg/--blue at the site tokens (and
 *   re-tinting the hardcoded blue badge chips) keeps every imported page in
 *   the site's 朱砂 family without touching generated styles.css. The dark
 *   layer below is appended later, so dark mode still wins.
 */
const siteHarmonizationCss = `
/* site-shell harmonization (see PaperLayout.astro) */
.paper-root .hero { padding-top: 48px; }
.paper-root {
  --bg: var(--background);
  --blue: var(--accent);
}
.paper-root .badge {
  background: color-mix(in srgb, var(--accent) 12%, transparent);
  color: var(--accent);
}
`;

/**
 * Dark-mode layer for imported paper2html pages — GENERAL, not per-page.
 * Every page rendered through this layout inherits it, so future imports get
 * dark support with no re-import and no edits to the generated styles.css.
 *
 * How it works:
 * 1. Variable override — the cheatsheet template drives its core palette from
 *    CSS custom properties on `.paper-root` (--bg/--paper/--ink/--muted/--line/
 *    --blue/--shadow). Re-declaring them under `html[data-theme="dark"]
 *    .paper-root` (higher specificity than the template's `.paper-root`) recolors
 *    the whole trunk: page/card surfaces, body text, borders, links, shadow.
 * 2. Property-level overrides — a handful of template classes hardcode light
 *    colors that no variable reaches (badge chips, card/metric hairline borders,
 *    callout/formula/table/figure surfaces, `.lead` text). These are stable
 *    class names from `assets/cheatsheet-template.html` (the paper2html output
 *    contract), so targeting them here covers every template-based page.
 *
 * Palette is tuned to the AstroPaper dark theme in `src/styles/theme.css`
 * (--background #1c1915, --foreground #e9e0d1, --muted #2a2520,
 * --muted-foreground #a99a85, --accent #e0714d): a warm松烟墨 family, never
 * pure black, so the paper reads as part of the site rather than a foreign
 * light panel.
 *
 * No-flash: the layer is plain CSS keyed on `html[data-theme]`, which the
 * inline FOUC script in Layout.astro sets before first paint — dark renders
 * directly with no white flash. KaTeX inherits `color` from `--ink`, so
 * formulas stay legible; data-URI images are left untouched (only their
 * `figure` container surface adapts).
 */
const paperDarkCss = `
html[data-theme="dark"] .paper-root {
  --bg: #1c1915;
  --paper: #262019;
  --ink: #e9e0d1;
  --muted: #a99a85;
  --line: #3a332b;
  --blue: #e0714d;
  --shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
}
html[data-theme="dark"] .paper-root .badge {
  background: rgba(224, 113, 77, 0.16);
  color: #e8a07f;
}
html[data-theme="dark"] .paper-root .badge.gray {
  background: rgba(255, 255, 255, 0.06);
  color: #c8bda9;
}
html[data-theme="dark"] .paper-root .metric,
html[data-theme="dark"] .paper-root section.card {
  border-color: rgba(255, 255, 255, 0.07);
}
html[data-theme="dark"] .paper-root .callout,
html[data-theme="dark"] .paper-root .mini-card,
html[data-theme="dark"] .paper-root .ref,
html[data-theme="dark"] .paper-root .formula,
html[data-theme="dark"] .paper-root figcaption {
  background: #221d16;
}
html[data-theme="dark"] .paper-root figure {
  background: var(--paper);
}
html[data-theme="dark"] .paper-root th {
  background: #2d2620;
}
html[data-theme="dark"] .paper-root .lead {
  color: #d8cdb9;
}
`;

const scopedCss = `${paperResetCss}\n${paperCss}\n${siteHarmonizationCss}\n${paperDarkCss}`;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  datePublished: date.toISOString(),
  author: [
    {
      "@type": "Person",
      name: config.site.author,
      ...(config.site.profile && { url: config.site.profile }),
    },
  ],
};

const contextLine = [topicTitle, seriesTitle].filter(Boolean).join(" · ");
---

<Layout title={`${title} | ${config.site.title}`} description={description}>
  <Fragment slot="head">
    <!-- Article meta for research pages -->
    <meta property="og:type" content="article" />
    <meta property="article:published_time" content={date.toISOString()} />
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(structuredData)}
    />
    <!-- Paper styles: pre-scoped under .paper-root by the research importer -->
    <style is:inline set:html={scopedCss}></style>
  </Fragment>

  <Header />

  <main id="main-content" class="w-full" data-pagefind-body>
    <div class="app-layout pt-6 sm:pt-8">
      <div
        class="text-muted-foreground flex flex-wrap items-center gap-x-3 gap-y-2 text-sm"
      >
        <span
          class="border-accent/40 text-accent rounded-full border px-2 py-0.5 text-xs font-medium"
        >
          {t.research.badge}
        </span>
        <Datetime pubDatetime={date} size="lg" />
        {contextLine && <span>{contextLine}</span>}
        {
          source && (
            <a
              href={source}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-accent underline underline-offset-4"
            >
              {t.research.sourceLabel}
            </a>
          )
        }
      </div>
      <ul class="mt-4 mb-2 flex flex-wrap gap-3">
        {tags.map(tag => <Tag tag={slugifyStr(tag)} tagName={tag} size="sm" />)}
      </ul>
    </div>

    <div class="paper-root" set:html={contentHtml} />
  </main>

  <Comments comments={entry.data.comments} />

  <Footer />
</Layout>

<script>
  import "@/scripts/render-paper-math";
</script>
